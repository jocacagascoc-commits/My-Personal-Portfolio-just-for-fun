      /* PROJECT POPUP */

.modal{
display:none;
position:fixed;
top:0;
left:0;
width:100%;
height:100%;
background:rgba(0,0,0,.8);
justify-content:center;
align-items:center;
z-index:9999;
}

.modal-content{
width:90%;
max-width:800px;
background:white;
border-radius:15px;
overflow:hidden;
position:relative;
animation:popup .3s ease;
}

.close{
position:absolute;
right:15px;
top:10px;
font-size:35px;
cursor:pointer;
z-index:10;
}

.slider{
display:flex;
overflow-x:auto;
scroll-snap-type:x mandatory;
scroll-behavior:smooth;
}

.slider img{
width:100%;
flex-shrink:0;
scroll-snap-align:center;
}

.slider::-webkit-scrollbar{
display:none;
}

@keyframes popup{
from{
transform:scale(.8);
opacity:0;
}
to{
transform:scale(1);
opacity:1;
}
}
